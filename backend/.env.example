# PromptAura Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Supabase (free at supabase.com) ─────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Stripe (free at stripe.com) ─────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── Stripe Price IDs (create in Stripe dashboard) ─
STRIPE_PRICE_BASIC_MONTHLY=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_BASIC_ANNUAL=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_PREMIUM_MONTHLY=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_PREMIUM_ANNUAL=price_XXXXXXXXXXXXXXXX

# ─── Fallback AI Keys (for users without own keys) ─
# Use ONLY if you want to offer AI without users' own keys
# This costs YOU money — recommend users provide their own
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
GEMINI_API_KEY=AIzaSyYOUR_GEMINI_KEY

# ─── App Config ───────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=your_very_long_random_secret_string_here_min_64_chars
APP_URL=https://promptaura.io
API_URL=https://api.promptaura.io

# ─── Optional: Email (Resend.com - free 3k/month) ─
RESEND_API_KEY=re_YOUR_RESEND_KEY
FROM_EMAIL=noreply@promptaura.io
